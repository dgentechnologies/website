rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    /**
     * Candidate resumes are sensitive.
     * Client-side reads are restricted to authenticated admins with a custom claim.
     * Client-side writes are blocked. Upload is handled server-side via Firebase Admin SDK.
     * Covers both the legacy path and the new website-namespaced path.
     */
    match /resumes/{listingId}/{fileName} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /website/resumes/{listingId}/{fileName} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // Default deny for all other storage paths.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}

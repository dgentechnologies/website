# -----------------------------
# Public Firebase Web Config
# -----------------------------
# Safe to expose in browser. Required for Firebase client SDK.
# Status in current .env: DONE
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_web_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_firebase_app_id
NEXT_PUBLIC_FIREBASE_DATABASE_ID=website

# Optional public aliases supported by this project
# Status in current .env: DONE
NEXT_PUBLIC_FIREBASE_WEBSITE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_WEBSITE_STORAGE_BUCKET=your-project-id.firebasestorage.app
NEXT_PUBLIC_FIREBASE_WEBSITE_DATABASE_ID=website

# -----------------------------
# Server Firebase Admin Config
# -----------------------------
# Keep secret. Never expose these values in client code.
# Status in current .env: DONE
FIREBASE_WEBSITE_PROJECT_ID=your-project-id
FIREBASE_WEBSITE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_WEBSITE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_CONTENT\n-----END PRIVATE KEY-----\n"
FIREBASE_WEBSITE_STORAGE_BUCKET=your-project-id.firebasestorage.app
FIREBASE_WEBSITE_DATABASE_ID=website

# Optional legacy names still supported by server code
# Status in current .env: optional, not needed if using FIREBASE_WEBSITE_* keys
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_CONTENT\n-----END PRIVATE KEY-----\n"
FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app

# -----------------------------
# Third-party Services
# -----------------------------
# Keep secret.
# Status in current .env: MISSING
# Required for Unsplash image fetching in blog generation and /api/unsplash.
UNSPLASH_ACCESS_KEY=your_unsplash_access_key

# Required only when running Genkit AI flows backed by Google GenAI.
# Set one of these keys. If both are present, the provider will use its normal precedence.
# Status in current .env: MISSING
GEMINI_API_KEY=your_gemini_api_key
# GOOGLE_API_KEY=your_google_ai_api_key
